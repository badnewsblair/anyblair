{
  "color": {
    "background": {
      "$type": "color",
      "default": { "$value": "{white}" },
      "subtle":  { "$value": "{off}" },
      "muted":   { "$value": "{gray-50}" },
      "inverse": { "$value": "{ink}" },
      "accent":  { "$value": "{accent-lt}" }
    },
    "text": {
      "$type": "color",
      "primary":   { "$value": "{ink}" },
      "body":      { "$value": "{gray-700}", "$description": "Long-form body copy — softer than primary." },
      "secondary": { "$value": "{gray-500}", "$description": "WCAG AA on white. Do not go lighter." },
      "tertiary":  { "$value": "{gray-300}", "$description": "Decorative only — fails AA on white." },
      "inverse":   { "$value": "{white}" },
      "accent":    { "$value": "{accent}" }
    },
    "border": {
      "$type": "color",
      "default": { "$value": "{gray-100}" },
      "subtle":  { "$value": "{gray-50}" },
      "strong":  { "$value": "{gray-300}" }
    },
    "interactive": {
      "$type": "color",
      "default": { "$value": "{accent}" },
      "hover":   { "$value": "{gray-700}" }
    },
    "on-dark": {
      "$type": "color",
      "$description": "White-alpha roles for always-dark surfaces (Contact, footer, profile header, primary card). Theme-agnostic — identical in light and dark.",
      "text-strong":     { "$value": "#ffffffb3", "$description": "70% — high-emphasis text on dark (8.98:1 on ink)." },
      "text":            { "$value": "#ffffff99", "$description": "60% — default text on dark (6.91:1)." },
      "text-muted":      { "$value": "#ffffff80", "$description": "50% — muted text on dark (5.25:1, AA floor)." },
      "text-faint":      { "$value": "#ffffff73", "$description": "45% — large or decorative emphasis only (4.47:1)." },
      "text-decorative": { "$value": "#ffffff40", "$description": "25% — decorative numerals, aria-hidden (no contrast requirement)." },
      "surface":         { "$value": "#ffffff0f", "$description": "6% — chip/inset fill on dark." },
      "line-faint":      { "$value": "#ffffff14", "$description": "8% — faint hairline on dark." },
      "line-subtle":     { "$value": "#ffffff1a", "$description": "10% — subtle divider on dark." },
      "line":            { "$value": "#ffffff1f", "$description": "12% — chip border on dark." },
      "border":          { "$value": "#ffffff2e", "$description": "18% — outline border on dark." },
      "border-strong":   { "$value": "#ffffff66", "$description": "40% — hover/emphasis border on dark." }
    }
  },

  "font": {
    "display": { "$type": "fontFamily", "$value": "{font-serif}" },
    "body":    { "$type": "fontFamily", "$value": "{font-sans}" },
    "ui":      { "$type": "fontFamily", "$value": "{font-sans}" }
  },

  "border-default": {
    "$type": "border",
    "$value": { "width": "{border-width}", "style": "solid", "color": "{color.border.default}" },
    "$description": "Composite 1px solid border using the default border color."
  }
}
